# i18n + quality gate — blocks pushes that would break the build or i18n coverage
echo "Running pre-push gate..."

# ── 1. TypeScript check ──
echo "▸ TypeScript..."
npm run typecheck || { echo "❌ TypeScript failed"; exit 1; }

# ── 2. Locale validation (missing keys, interpolation parity) ──
echo "▸ Locale validation..."
npm run i18n:validate || { echo "❌ Locale validation failed — run 'npm run i18n:fix'"; exit 1; }

# ── 3. i18n tests (language switching, stale translations) ──
echo "▸ i18n tests..."
npx jest __tests__/i18n-switching.test.ts __tests__/i18n-runtime-stale.test.ts --no-coverage --silent || { echo "❌ i18n tests failed"; exit 1; }

# ── 4. Unit tests ──
echo "▸ Unit tests..."
npm run test || { echo "❌ Tests failed"; exit 1; }

echo "✔ All gates passed"
