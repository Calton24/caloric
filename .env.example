# Supabase Configuration
# Get these from: https://supabase.com/dashboard/project/_/settings/api

EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Sentry Configuration (Optional - Production Error Tracking)
# Get this from: https://sentry.io/settings/projects/your-project/keys/
# EXPO_PUBLIC_SENTRY_DSN=https://your-key@o123456.ingest.sentry.io/123456

# Optional: Enable Sentry in development (disabled by default)
# EXPO_PUBLIC_ENABLE_SENTRY_IN_DEV=true

# Sentry Source Map Upload (build time only)
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=your-project-slug
# SENTRY_AUTH_TOKEN=your-auth-token

# Auth providers (default OFF — enable per app)
# EXPO_PUBLIC_AUTH_GOOGLE=0
# EXPO_PUBLIC_AUTH_APPLE=0

# Optional: App Profile (defaults to "default")
# EXPO_PUBLIC_APP_PROFILE=default
# EXPO_PUBLIC_APP_ENV=dev
