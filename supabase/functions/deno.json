{
  "compilerOptions": {
    "lib": ["deno.ns", "deno.window", "dom", "dom.iterable", "es2022"],
    "strict": true,
    "noImplicitAny": false
  },
  "importMap": "./import_map.json",
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": false
  },
  "exclude": [
    "../../app/**",
    "../../src/**",
    "../../components/**",
    "../../node_modules/**"
  ]
}
