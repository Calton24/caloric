{
  "editor.codeActionsOnSave": {
    "source.fixAll": "explicit",
    "source.organizeImports": "explicit",
    "source.sortMembers": "explicit"
  },

  // Deno settings - enable ONLY for Edge Functions
  "deno.enable": false,
  "deno.enablePaths": ["./supabase/functions"],
  "deno.config": "./supabase/functions/deno.json",
  "deno.importMap": "./supabase/functions/import_map.json",
  "deno.lint": true,
  "deno.unstable": [],
  "deno.suggest.imports.hosts": {
    "https://deno.land": true,
    "https://esm.sh": true
  },

  // Prevent TypeScript server from analyzing Deno files
  "typescript.tsdk": "node_modules/typescript/lib",
  "typescript.enablePromptUseWorkspaceTsdk": true,

  // Exclude Deno files from TypeScript analysis
  "files.exclude": {
    "**/supabase/functions/**/*.ts": false
  },

  // Associate Deno files correctly
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
