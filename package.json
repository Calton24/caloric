{
  "name": "mobile-core",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:edge": "deno test --config supabase/functions/deno.json --allow-env --allow-net supabase/functions/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:edge": "deno check --config supabase/functions/deno.json supabase/functions/create-checkout-session/index.ts supabase/functions/stripe-webhook/index.ts",
    "check": "npm run typecheck && npm run typecheck:edge",
    "check:edge": "npm run typecheck:edge",
    "validate": "npm run check && npm run lint && npm run test && npm run test:edge",
    "mobile-core:verify": "node scripts/verify-mobile-core.js",
    "mobile-core:verify:deep": "npm run mobile-core:verify && npx jest --detectOpenHandles --runInBand",
    "maestro:test": "maestro test maestro/flows",
    "ios:sim:build": "node scripts/ios-sim-build.js",
    "ios:sim:install": "node scripts/ios-sim-install.js",
    "maestro:ci:ios": "node scripts/maestro-ci-ios.js",
    "maestro:ci:ios:fast": "SKIP_BUILD=1 node scripts/maestro-ci-ios.js",
    "maestro:ci:ios:full": "SKIP_BUILD=0 node scripts/maestro-ci-ios.js",
    "mobile-core:security": "node scripts/security-audit.js",
    "mobile-core:verify:security": "npm run mobile-core:security && npm run check && npm run lint && npm run test",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/ui": "~0.2.0-beta.9",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.94.1",
    "@superwall/react-native-superwall": "^2.1.7",
    "expo": "~54.0.32",
    "expo-application": "^7.0.8",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "^17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "expo-widgets": "^0.0.0",
    "i18next": "^25.8.13",
    "live-activity-module": "file:./modules/live-activity",
    "lucide-react-native": "^0.574.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "^0.6.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.0.1",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.5",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.2.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
