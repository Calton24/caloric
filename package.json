{
  "name": "caloric",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "start:dev-client": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:edge": "deno test --config supabase/functions/deno.json --allow-env --allow-net supabase/functions/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:edge": "deno check --config supabase/functions/deno.json supabase/functions/create-checkout-session/index.ts supabase/functions/stripe-webhook/index.ts",
    "check": "npm run typecheck && npm run typecheck:edge",
    "check:edge": "npm run typecheck:edge",
    "validate": "npm run check && npm run lint && npm run test && npm run test:edge",
    "caloric:verify": "node scripts/verify-caloric.js",
    "caloric:verify:deep": "npm run caloric:verify && npx jest --detectOpenHandles --runInBand",
    "maestro:test": "maestro test maestro/flows",
    "ios:sim:build": "node scripts/ios-sim-build.js",
    "ios:sim:install": "node scripts/ios-sim-install.js",
    "maestro:ci:ios": "node scripts/maestro-ci-ios.js",
    "maestro:ci:ios:fast": "SKIP_BUILD=1 node scripts/maestro-ci-ios.js",
    "maestro:ci:ios:full": "SKIP_BUILD=0 node scripts/maestro-ci-ios.js",
    "caloric:security": "node scripts/security-audit.js",
    "caloric:verify:security": "npm run caloric:security && npm run check && npm run lint && npm run test",
    "prepare": "husky",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/ui": "~0.2.0-beta.9",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-native-ml-kit/image-labeling": "^2.0.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@supabase/supabase-js": "^2.103.0",
    "expo": "~54.0.32",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "^7.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "^15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-store-review": "~9.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-tracking-transparency": "~6.0.8",
    "expo-updates": "~29.0.16",
    "expo-web-browser": "~15.0.10",
    "expo-widgets": "^55.0.13",
    "i18next": "^25.8.13",
    "live-activity-module": "file:./modules/live-activity",
    "lucide-react-native": "^0.574.0",
    "react": "19.1.0",
    "react-dom": "19.2.5",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-health": "^1.13.0",
    "react-native-purchases": "^9.15.0",
    "react-native-purchases-ui": "^9.15.0",
    "react-native-reanimated": "^4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-view-shot": "4.0.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.12"
  },
  "devDependencies": {
    "@testing-library/react-native": "^12.9.0",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "patch-package": "^8.0.1",
    "prettier": "^3.4.5",
    "react-test-renderer": "19.2.5",
    "ts-jest": "^29.2.6",
    "typescript": "~5.9.2"
  },
  "private": true
}
